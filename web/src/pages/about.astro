---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuickAnswer from '../components/QuickAnswer.astro';
import Footer from '../components/Footer.astro';
import AboutPageSchema from '../components/schema/AboutPageSchema.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import PersonSchema from '../components/schema/PersonSchema.astro';
import FAQPageSchema from '../components/schema/FAQPageSchema.astro';
import { SITE } from '../consts';

const aboutFaqs = [
  {
    q: 'Who built Pour Picks?',
    a: 'Pour Picks was built and is operated by Bob Guillow, an independent solo developer. There is no outside investor, no advertising network, and no parent company behind the app. All product and privacy decisions are made by one person.',
  },
  {
    q: 'What is Timberline Ventures LLC?',
    a: 'Timberline Ventures LLC is the legal business entity that owns and operates Pour Picks. It is a single-member LLC founded by Bob Guillow. The LLC name appears on the App Store developer page and in the app\'s legal agreements.',
  },
  {
    q: 'How can I contact the Pour Picks team?',
    a: `Email is the canonical contact channel: ${SITE.supportEmail}. There is no DM channel, no social inbox, and no support chat. Press, partnership, product feedback, and review inquiries all go to that address. Replies typically arrive within a day.`,
  },
];

const quickAnswer =
  'Pour Picks is an iOS journal and cellar catalog for adult bourbon collectors, ' +
  'built and operated by an independent developer. The app does not sell alcohol, ' +
  'show alcohol ads, or encourage consumption. It is a private reference for tracking ' +
  'what you own, what you pour, and what your collection is worth.';
---
<BaseLayout
  title="About"
  description="About Pour Picks, who runs it, what it is, what it isn't, and how it makes money."
  path="/about"
>
  <Fragment slot="head">
    <AboutPageSchema />
    <PersonSchema />
    <FAQPageSchema faqs={aboutFaqs} />
    <BreadcrumbSchema crumbs={[{ name: 'About', url: `${SITE.url}/about` }]} />
  </Fragment>

  <p class="brand">{SITE.name}</p>
  <h1>About Pour Picks</h1>

  <QuickAnswer text={quickAnswer} />

  <section class="is-isnt">
    <div class="is-col">
      <h2>What it is</h2>
      <ul>
        <li>A cellar catalog for what you own, by distillery, expression, proof, age, and fill level.</li>
        <li>An AI label scanner that names a bottle from its front label.</li>
        <li>A running value for the collection, MSRP or the price you actually paid.</li>
        <li>A private journal for every pour, with separate nose, palate, and finish.</li>
      </ul>
    </div>
    <div class="isnt-col">
      <h2>What it is not</h2>
      <ul>
        <li>Not a retailer. It does not sell, distribute, or deliver alcohol.</li>
        <li>Not a marketplace. No listings, no buy or sell, no auctions, no allocation tools.</li>
        <li>No ads of any kind, alcohol or otherwise.</li>
        <li>Not a nudge to drink more. It is for people who already collect.</li>
        <li>No health, location, or financial data. See the <a href="/privacy">privacy policy</a>.</li>
      </ul>
    </div>
  </section>

  <dl class="colophon">
    <div class="colophon-row">
      <dt>Who runs it</dt>
      <dd>Built and operated by an independent solo developer, published by {SITE.legalEntity}. No investor, no ad network. One person makes the calls and answers <a href={`mailto:${SITE.supportEmail}`}>{SITE.supportEmail}</a>.</dd>
    </div>
    <div class="colophon-row">
      <dt>How it makes money</dt>
      <dd>The core app is free. Cask Club, the paid tier, adds advanced tracking and full journaling. That is the whole model, billed through Apple, so payment information never touches Pour Picks' servers.</dd>
    </div>
    <div class="colophon-row">
      <dt>Editorial standards</dt>
      <dd>Articles are written in-house from first-hand collecting and cited primary sources: distillery technical sheets, TTB filings, and reference books. Facts are linked, opinions are labeled, and a date changes only when the content does.</dd>
    </div>
    <div class="colophon-row">
      <dt>Responsible use</dt>
      <dd>Pour Picks does not promote drinking. Excess is harmful to health, and impaired driving is illegal everywhere we operate. The full disclaimer lives in the <a href="/terms">Terms of Use</a>.</dd>
    </div>
    <div class="colophon-row">
      <dt>Contact</dt>
      <dd>Press, partnership, or product feedback all go to <a href={`mailto:${SITE.supportEmail}`}>{SITE.supportEmail}</a>. No DM channel, no chat. Replies usually land within a day.</dd>
    </div>
  </dl>

  <Footer />
</BaseLayout>
