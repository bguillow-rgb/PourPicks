---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import { SITE } from '../consts';

// Support FAQs structured as question H2s so AI engines can extract them
// cleanly via FAQPage schema.
const faqs = [
  {
    q: 'How do I delete my Pour Picks account?',
    a:
      'Open the app, go to the Profile tab, scroll to the bottom, and tap Delete Account, then confirm. This permanently deletes your cellar, tasting reviews, scan history, ratings, and bottle suggestions. The action cannot be undone. If you have lost access to the app, email support@pourpicks.app from the address on your account with the subject "Delete My Account" and we will remove your data within 7 days.',
  },
  {
    q: 'How do I cancel my Cask Club subscription?',
    a:
      'Subscriptions are managed by Apple, not by Pour Picks. On your iPhone or iPad, open Settings, tap your name at the top, tap Subscriptions, then tap Pour Picks Pro (Cask Club) and Cancel Subscription. Cancellation takes effect at the end of the current billing period. Deleting your account in the app does not automatically cancel an active subscription \u2014 you must cancel it separately in iOS Settings.',
  },
  {
    q: 'The Pour Concierge can not identify my bottle \u2014 what can I try?',
    a:
      'Fill the frame with the front label and shoot in even, bright light \u2014 avoid glare and motion blur. Hold steady so text stays in focus. If the read still misses, tap "Describe in words" to give the AI a second pass with no image, search the catalog manually, or tap "Suggest this bottle" and the catalog team will add it. The 4.5-second undo snackbar lets you reverse any cellar add right after a confirm.',
  },
  {
    q: 'How old do I have to be to use Pour Picks?',
    a:
      'Pour Picks is intended for adults of legal drinking age (21+ in the United States). A 21+ age gate is enforced on first launch.',
  },
  {
    q: 'Is Pour Picks a retailer?',
    a:
      'No. Pour Picks is a reference and journal app for bourbon collectors. It does not sell, distribute, deliver, or facilitate the purchase of alcohol. Its focus is on cataloging, organizing, and tracking the value of a collection.',
  },
  {
    q: 'How many free scans do I get?',
    a:
      'Guests get 5 lifetime scans, signed-in non-Pro users get 10, and Cask Club members get unlimited scans. Rate limits of roughly 30 per hour and 100 per day apply per device or account to keep the AI affordable.',
  },
];
---
<BaseLayout
  title="Support"
  description="Pour Picks support \u2014 account deletion, subscription cancellation, scanner tips, and contact information."
  path="/support"
>
  <Fragment slot="head">
    <BreadcrumbSchema crumbs={[{ name: 'Support', url: `${SITE.url}/support` }]} />
  </Fragment>

  <p class="brand">{SITE.name}</p>
  <h1>Support</h1>
  <p class="effective">We answer every email. Usually within a day.</p>

  <h2>Contact</h2>
  <p>
    For any question, bug report, feature request, or feedback:
    <a href={`mailto:${SITE.supportEmail}`}>{SITE.supportEmail}</a>.
  </p>
  <p>
    Please include your account email, your iOS version, and your app version
    (found at the bottom of the Profile tab) \u2014 it helps trace issues faster.
  </p>

  <FAQ faqs={faqs} heading="Common Questions" />

  <Footer />
</BaseLayout>
