---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import SoftwareApplicationSchema from '../components/schema/SoftwareApplicationSchema.astro';
import FAQPageSchema from '../components/schema/FAQPageSchema.astro';
import { SITE } from '../consts';

const featuresFaqs = [
  {
    q: 'Does Pour Picks work with all bourbon bottles?',
    a: 'Pour Picks covers thousands of American whiskeys — bourbon, rye, Tennessee whiskey, wheat whiskey, and single-malt American. The AI label scanner handles most commercially available bottles. If a bottle is missing or the scan doesn\'t match, users can describe the bottle in text for a second pass, search manually, or suggest an addition to the catalog.',
  },
  {
    q: 'Is Pour Picks free to use?',
    a: 'Yes. The core app is free: unlimited browsing, the palate quiz, and basic cellar tracking. A Cask Club subscription ($2.99/month) unlocks advanced cellar features, unlimited AI scans, full journaling, and collection value tracking. Subscriptions are billed through Apple — payment information never touches Pour Picks servers.',
  },
  {
    q: 'What is the AI label scanner?',
    a: 'The AI label scanner — called Pour Concierge — uses Claude Vision to read a bottle\'s front label through your iPhone camera. It identifies the distillery, expression, and proof, then matches the result against the catalog, usually in under a second. If the read isn\'t right, you can correct it or search manually.',
  },
  {
    q: 'How does Pour Picks recommend bourbon?',
    a: 'Pour Picks has two recommendation modes. The palate quiz (3 questions basic, 9 questions advanced) matches your flavor preferences to catalog entries. The "Pour Tonight" feature reads your actual cellar and picks a specific bottle to pour tonight based on what you\'ve poured recently, your personal ratings, and the season — it recommends from what you already own, not purchases.',
  },
];
---
<BaseLayout
  title="Features"
  description="A closer look at Pour Picks: cellar catalog, tasting journal, AI bottle identification, palate-matching quiz, and curated browse."
  path="/features"
>
  <Fragment slot="head">
    <SoftwareApplicationSchema featureList="Bourbon cellar tracker, AI label scanner, taste quiz, personalized recommendations, tasting journal, Pour Tonight feature" />
    <FAQPageSchema faqs={featuresFaqs} />
    <BreadcrumbSchema crumbs={[{ name: 'Features', url: `${SITE.url}/features` }]} />
    <link rel="apple-touch-icon" href="/icon.png" />
  </Fragment>

  <p class="brand">{SITE.name}</p>
  <h1>Features</h1>
  <p class="effective">Everything Pour Picks does, in one place.</p>

  <section class="feature-row">
    <div class="feature-row-copy">
      <h3>Your cellar, organized</h3>
      <p>Track every bottle by distillery, expression, proof, age, and fill level. Mark bottles Owned, Wishlist, or Finished, and capture your own ratings the moment you set the glass down.</p>
      <p>Filter by status, search by name, and see at a glance what's open, what's still sealed, and what's earned a place on the wishlist.</p>
    </div>
  </section>

  <section class="feature-row feature-row--reverse">
    <div class="feature-row-copy">
      <h3>A catalog built for discovery</h3>
      <p>Browse a curated database of thousands of American whiskeys. Filter by category (bourbon, rye, Tennessee, wheat, single-malt American), distillery, age, proof, and price tier &mdash; or open the world-spirits scope when you want to look beyond.</p>
      <p>Every entry is curated with mash bill, flavor tags, food and drink pairings, and a path back to your cellar.</p>
    </div>
  </section>

  <section class="feature-row">
    <div class="feature-row-copy">
      <h3>Pour Concierge: scan any bottle</h3>
      <p>Point your camera at the front label. The Pour Concierge uses Claude Vision to identify the distillery, expression, and proof, then matches against the catalog &mdash; usually in under a second.</p>
      <p>Best-effort by design: if the read isn't right, describe the bottle in words for a second pass, search manually, or suggest a new bottle for the catalog. The undo snackbar gives you 4.5 seconds to reverse any cellar add.</p>
    </div>
  </section>

  <section class="feature-row feature-row--reverse">
    <div class="feature-row-copy">
      <h3>Find your next pour</h3>
      <p>The basic three-question quiz matches your palate to the right catalog entries. The advanced nine-question quiz goes deep with adventure-mode reranking &mdash; "Stick to Classics" boosts the icons, "Surprise Me" pulls forward deep cuts.</p>
    </div>
  </section>

  <section class="feature-row">
    <div class="feature-row-copy">
      <h3>A tasting journal that remembers</h3>
      <p>Log every pour with overall rating, separate nose / palate / finish ratings, served-with (neat, rocks, water, cocktail), pour size, and freeform notes. Edit and revisit any entry later.</p>
      <p>Public aggregate rating gets shown on the bottle detail page so other collectors can decide whether to chase it.</p>
    </div>
  </section>

  <section class="feature-row feature-row--reverse">
    <div class="feature-row-copy">
      <h3>Collection value at a glance</h3>
      <p>Cellar value updates with every add: MSRP from the catalog as the default, with overrides for the price you actually paid. Per-bottle and per-line totals, with quantity steppers for the bottles you have multiples of.</p>
    </div>
  </section>

  <section class="cta">
    <h2 class="section-title">Ready when you are</h2>
    <p class="cta-body">
      Pour Picks lands on the App Store soon. Questions, feedback, or want a heads-up at launch? Email
      <a href={`mailto:${SITE.supportEmail}`}>{SITE.supportEmail}</a>.
    </p>
  </section>

  <Footer />
</BaseLayout>
