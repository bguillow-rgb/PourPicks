---
import { getCollection } from 'astro:content';
import { YouTube } from 'astro-embed';
import BaseLayout from '../layouts/BaseLayout.astro';
import QuickAnswer from '../components/QuickAnswer.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import SoftwareApplicationSchema from '../components/schema/SoftwareApplicationSchema.astro';
import VideoObjectSchema from '../components/schema/VideoObjectSchema.astro';
import { SITE } from '../consts';

// Latest 3 published articles for the homepage "From the Blog" teaser.
// Drafts are excluded automatically because they have published:false.
const latestArticles = (
  await getCollection('articles', ({ data }) => data.published)
)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const quickAnswer =
  'Pour Picks is a hobby and lifestyle iOS app for adult bourbon collectors. ' +
  'It catalogs your cellar, scans bottles to identify what you own, ' +
  'tracks the value of your collection over time, and gives you a private ' +
  'journal to log every pour. It does not sell alcohol.';

const faqs = [
  {
    q: 'What is Pour Picks?',
    a:
      'Pour Picks is an iOS journal app for adult bourbon collectors. You catalog your cellar, scan bottles to identify them, track collection value, and log tasting notes, all in one private reference.',
  },
  {
    q: 'Is Pour Picks a retailer?',
    a:
      'No. Pour Picks does not sell alcohol, distribute alcohol, or encourage consumption. It is a reference, journal, and cellar catalog for collectors of legal drinking age.',
  },
  {
    q: 'How old do I have to be to use Pour Picks?',
    a:
      'Pour Picks is intended for adults of legal drinking age (21+ in the United States). A 21+ age gate is enforced on first launch.',
  },
  {
    q: 'How does the bottle scanner work?',
    a:
      'Point the camera at the front label. The Pour Concierge scanner uses Claude Vision to identify the distillery, expression, and proof, then matches against our catalog of thousands of American whiskeys. If recognition fails you can describe the bottle in words, search manually, or suggest a bottle to be added.',
  },
  {
    q: 'Is Pour Picks free?',
    a:
      'Yes, the core app is free. A Pro subscription (Cask Club) unlocks advanced collection tracking, the full Pour Concierge scanner, tasting reviews, and pairing recommendations. Pro is managed through Apple subscriptions and can be canceled any time in iOS Settings.',
  },
  {
    q: 'Is my collection data private?',
    a:
      'Yes. Your cellar, tasting reviews, scan history, and ratings are tied to your account and never shared, sold, or used for advertising. See the Privacy Policy for the full breakdown.',
  },
  {
    q: 'Will Pour Picks be available on Android?',
    a:
      'Pour Picks launched on iOS first. An Android release is on the roadmap but not yet scheduled.',
  },
];
---
<BaseLayout
  title={SITE.name}
  description={SITE.description}
  path="/"
>
  <Fragment slot="head">
    <SoftwareApplicationSchema />
    <VideoObjectSchema />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta property="og:image" content={`${SITE.url}/icon.png`} />
  </Fragment>

  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Bourbon cellar &middot; iOS</p>
      <h1>The collector&rsquo;s <em>cellar.</em></h1>
      <p class="hero-tagline">Catalog every bottle, scan a label to identify what you own, track your collection&rsquo;s value, and journal every pour in one private reference.</p>

      {/* Hero CTA, live on the App Store since 2026-05-09. */}
      <a class="hero-cta" href={SITE.appStoreUrl}>Download on iOS &rarr;</a>
      <p class="hero-trust">For adults 21+ &middot; No ads &middot; Your collection stays yours</p>
    </div>

    <aside class="bottlelabel" aria-label="Example bottle in your cellar">
      <p class="bottlelabel-house">Buffalo Trace Distillery</p>
      <p class="bottlelabel-name">Eagle Rare</p>
      <p class="bottlelabel-style">Kentucky Straight Bourbon Whiskey</p>

      <dl class="bottlelabel-stats">
        <div>
          <dt>Age</dt>
          <dd>10<span>Years</span></dd>
        </div>
        <div>
          <dt>Proof</dt>
          <dd>90<span>45% ABV</span></dd>
        </div>
      </dl>

      <p class="bottlelabel-mash">Corn 75 &middot; Rye 10 &middot; Malt 15</p>

      <p class="bottlelabel-foot"><span>Cellar value</span><strong>$489</strong></p>
    </aside>
  </section>

  <QuickAnswer text={quickAnswer} />

  <section class="features">
    <h2 class="section-title">Built for collectors</h2>

    <div class="feature-grid">
      <div class="feature">
        <div class="feature-icon" aria-hidden="true">No. 01 &middot; Cellar</div>
        <h3>Your cellar, organized</h3>
        <p>Track every bottle by distillery, expression, proof, age, and fill level. Snap the label, the Pour Concierge does the rest.</p>
      </div>

      <div class="feature">
        <div class="feature-icon" aria-hidden="true">No. 02 &middot; Journal</div>
        <h3>A journal that remembers</h3>
        <p>Log each pour with nose, palate, finish, served-with, and pour size. Your tasting history, searchable.</p>
      </div>

      <div class="feature">
        <div class="feature-icon" aria-hidden="true">No. 03 &middot; Value</div>
        <h3>Collection value at a glance</h3>
        <p>MSRP-aware pricing keeps a running total of what's resting in your cellar, with overrides for bottles you bought above or below shelf.</p>
      </div>

      <div class="feature">
        <div class="feature-icon" aria-hidden="true">No. 04 &middot; Palate</div>
        <h3>Discover what you'll love</h3>
        <p>A short profile quiz finds catalog entries matched to your palate, from a curated database of thousands of American whiskeys.</p>
      </div>
    </div>

    <p class="features-link"><a href="/features">See every feature &rarr;</a> &middot; <a href="/bourbon-inventory-app">The bourbon inventory app &rarr;</a></p>
  </section>

  <section class="demo">
    <h2 class="section-title">See it in action</h2>
    <p class="demo-sub">A quick look at scanning a bottle and logging a pour.</p>
    <div class="demo-video">
      <YouTube id="29Ot-QKrZgs" title="Pour Picks in action" />
    </div>
  </section>

  <h2>How does Pour Picks make money?</h2>
  <p>
    Pour Picks is free to download and use. A Cask Club subscription unlocks
    advanced collection tracking and journaling features. There are no ads,
    no data selling, and no alcohol promotion. The app does not sell alcohol.
  </p>

  <div class="cta-row">
    {SITE.appStoreUrl ? (
      <a class="cta" href={SITE.appStoreUrl}>Download on iOS</a>
    ) : (
      <span class="cta cta--disabled">App Store (Coming Soon)</span>
    )}
  </div>

  {latestArticles.length > 0 && (
    <section class="blog-teaser">
      <h2 class="section-title">From the Blog</h2>
      <ul class="blog-list">
        {latestArticles.map((a) => (
          <li>
            <a href={`/articles/${a.slug}`}>{a.data.title}</a>
            <p>{a.data.description}</p>
          </li>
        ))}
      </ul>
      <p class="features-link"><a href="/articles">All articles &rarr;</a></p>
    </section>
  )}

  <FAQ faqs={faqs} />

  <Footer />
</BaseLayout>
