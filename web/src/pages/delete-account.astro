---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import { SITE } from '../consts';

// Required public URL for App Store Review Guideline 5.1.1(v), provide a
// publicly reachable account-deletion endpoint. Migrated from the legacy
// public/delete-account.html.
---
<BaseLayout
  title="Delete Your Account"
  description="How to delete your Pour Picks account and all associated data, in-app, by email, or by request."
  path="/delete-account"
>
  <Fragment slot="head">
    <BreadcrumbSchema crumbs={[{ name: 'Delete Your Account', url: `${SITE.url}/delete-account` }]} />
  </Fragment>

  <p class="brand">{SITE.name}</p>
  <h1>Delete Your Account</h1>
  <p class="effective">You can delete your Pour Picks account and all associated data at any time.</p>

  <h2>Option 1: Delete From Inside the App (recommended)</h2>
  <ol>
    <li>Open Pour Picks on your iPhone.</li>
    <li>Sign in with the account you want to delete.</li>
    <li>Tap the <strong>Profile</strong> tab.</li>
    <li>Scroll to the bottom and tap <strong>Delete Account</strong>.</li>
    <li>Confirm by tapping <strong>Delete</strong>.</li>
  </ol>
  <p>Your account and all data will be removed immediately.</p>

  <h2>Option 2: Email Request</h2>
  <p>
    If you cannot access the app, send an email to
    <a href={`mailto:${SITE.supportEmail}?subject=Delete%20My%20Account`}>{SITE.supportEmail}</a>
    from the email address associated with your account. Include the subject
    line <strong>"Delete My Account"</strong>.
  </p>
  <p>
    We will permanently remove your account and data within <strong>7 days</strong>
    and send a confirmation when deletion is complete.
  </p>

  <h2>What gets deleted</h2>
  <ul>
    <li>Your sign-in identity (Apple or Google).</li>
    <li>Your profile (display name, avatar, taste profile).</li>
    <li>Your cellar (wishlist, owned, finished items).</li>
    <li>Your tasting reviews and any photos you uploaded.</li>
    <li>Your scan history and uploaded scan images.</li>
    <li>Your quiz results.</li>
    <li>Any community ratings, reviews, or bottle suggestions you submitted.</li>
  </ul>

  <h2>What is retained</h2>
  <p>For legal, billing, and fraud-prevention purposes we may retain:</p>
  <ul>
    <li>Anonymized purchase records (Apple's responsibility).</li>
    <li>Anonymized aggregate analytics that cannot be traced back to you.</li>
  </ul>

  <h2>Subscriptions</h2>
  <p>
    Deleting your account does <strong>not</strong> automatically cancel an
    active App Store subscription. You must cancel the subscription
    separately in <strong>Settings → Apple ID → Subscriptions</strong> on your
    iPhone, or it will continue to renew.
  </p>

  <h2>Questions?</h2>
  <p>
    Email <a href={`mailto:${SITE.supportEmail}`}>{SITE.supportEmail}</a>.
  </p>

  <Footer />
</BaseLayout>
