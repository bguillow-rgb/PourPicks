---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import BreadcrumbSchema from '../../components/schema/BreadcrumbSchema.astro';
import { SITE } from '../../consts';

// In dev mode, include drafts. In production, only published articles
// surface in the index.
const includeDrafts = import.meta.env.DEV;
const articles = (
  await getCollection('articles', ({ data }) =>
    includeDrafts ? true : data.published
  )
).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Pour Picks Blog — Bourbon Collector Guides',
  description: 'Guides and references for bourbon collectors covering storage, oxidation, valuation, identification, and more.',
  url: `${SITE.url}/articles`,
  inLanguage: SITE.locale,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: articles.map((a, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: a.data.title,
      url: `${SITE.url}/articles/${a.slug}`,
    })),
  },
};
---
<BaseLayout
  title="Blog"
  description="The Pour Picks blog \u2014 guides and references for bourbon collectors covering storage, oxidation, valuation, identification, and more."
  path="/articles"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <BreadcrumbSchema crumbs={[{ name: 'Blog', url: `${SITE.url}/articles` }]} />
  </Fragment>

  <p class="brand">{SITE.name}</p>
  <h1>Blog</h1>
  <p class="effective">Field-tested references for bourbon collectors.</p>

  {articles.length === 0 ? (
    <p>The first articles are being written now. Check back soon, or email <a href={`mailto:${SITE.supportEmail}`}>{SITE.supportEmail}</a> if there is a topic you want covered.</p>
  ) : (
    <ul>
      {articles.map((a) => (
        <li>
          <a href={`/articles/${a.slug}`}>{a.data.title}</a>
          <p>{a.data.description}</p>
        </li>
      ))}
    </ul>
  )}

  <Footer />
</BaseLayout>
