---
import { SITE } from '../../consts';

// Article schema with Speakable on the Quick Answer block (#quick-answer).
// Speakable signals to AI engines and voice assistants which passage best
// answers the target query.
interface Props {
  title: string;
  description: string;
  url: string;
  publishedAt: Date;
  updatedAt?: Date;
  author: string;
  // Optional hero image URL. Falls back to the site icon when not provided.
  heroImage?: string;
  heroImageWidth?: number;
  heroImageHeight?: number;
}

const {
  title,
  description,
  url,
  publishedAt,
  updatedAt,
  heroImage,
  heroImageWidth,
  heroImageHeight,
} = Astro.props;

const imageUrl = heroImage ?? `${SITE.url}/icon-512.png`;
const imageWidth = heroImageWidth ?? 512;
const imageHeight = heroImageHeight ?? 512;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url,
  image: {
    '@type': 'ImageObject',
    url: imageUrl,
    width: imageWidth,
    height: imageHeight,
  },
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  author: {
    '@type': 'Person',
    name: SITE.founder.name,
    url: `${SITE.url}/about`,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE.url}/icon-512.png`,
    },
  },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#quick-answer'],
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': url,
  },
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
