---
import { SITE } from '../../consts';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.url,
  logo: `${SITE.url}/icon-512.png`,
  email: SITE.supportEmail,
  sameAs: SITE.founder.sameAs.filter(Boolean),
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
