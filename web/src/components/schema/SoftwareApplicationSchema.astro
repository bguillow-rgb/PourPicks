---
import { SITE } from '../../consts';

// MobileApplication schema for the iOS app. Once Android ships, render this
// twice with the relevant operatingSystem + downloadUrl, or emit an array.
//
// Conditional fields:
// - downloadUrl is omitted until SITE.appStoreUrl is set, so we don\u2019t emit
//   a broken link claim.
// - aggregateRating is intentionally omitted until there are real ratings;
//   fabricating ratings is a manual-action risk.

interface Props {
  // Optional feature list to surface on pages that describe the app in detail.
  featureList?: string;
}

const { featureList } = Astro.props;

const base: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: `${SITE.name}: Bourbon & Whiskey`,
  description: SITE.description,
  operatingSystem: 'iOS',
  applicationCategory: 'LifestyleApplication',
  // Free with optional Pro IAP. When pricing is confirmed, replace with
  // detailed Offer including price, priceCurrency, and availability.
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  url: SITE.appStoreUrl,
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
};

if (SITE.appStoreUrl) {
  base.downloadUrl = SITE.appStoreUrl;
  base.installUrl = SITE.appStoreUrl;
}

if (featureList) {
  base.featureList = featureList;
}
---
<script type="application/ld+json" set:html={JSON.stringify(base)} />
